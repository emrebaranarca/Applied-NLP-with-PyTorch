\nfrom tensorflow.keras.preprocessing.text import Tokenizer\nfrom tensorflow.keras.utils import pad_sequences\nimport copy\n\n# --- 1. HİPERPARAMETRELER ---\nVOCAB_SIZE = 10000\nMAX_LEN = 50\nBATCH_SIZE = 32\nEMBEDDING_DIM = 64\nRNN_UNITS = 64\nEPOCHS = 15\n\n\nX_train_seq, X_val_seq, y_train, y_val = train_test_split(\n    X_pad_train, y, test_size=0.2, random_state=42, stratify=y\n)\n\n# --- 3. PYTORCH VERİ HAZIRLIĞI ---\nX_train_tensor = torch.tensor(X_train_seq, dtype=torch.long)\ny_train_tensor = torch.tensor(np.array(y_train), dtype=torch.float32).unsqueeze(1)\n\nX_val_tensor = torch.tensor(X_val_seq, dtype=torch.long)\ny_val_tensor = torch.tensor(np.array(y_val), dtype=torch.float32).unsqueeze(1)\n\ntrain_loader = DataLoader(TensorDataset(X_train_tensor, y_train_tensor), batch_size=BATCH_SIZE, shuffle=True)\nval_loader = DataLoader(TensorDataset(X_val_tensor, y_val_tensor), batch_size=BATCH_SIZE, shuffle=False)\n\n# --- 4. EARLY STOPPING SINIFI ---\nclass EarlyStopping:\n    def __init__(self, patience=3, min_delta=0):\n        self.patience = patience\n        self.min_delta = min_delta\n        self.counter = 0\n        self.best_loss = None\n        self.early_stop = False\n        self.best_weights = None\n\n    def __call__(self, val_loss, model):\n        if self.best_loss is None:\n            self.best_loss = val_loss\n            self.best_weights = copy.deepcopy(model.state_dict())\n        elif val_loss > self.best_loss - self.min_delta:\n            self.counter += 1\n            print(f\" EarlyStopping sayacı: {self.counter} / {self.patience}\")\n            if self.counter >= self.patience:\n                self.early_stop = True\n        else:\n            self.best_loss = val_loss\n            self.best_weights = copy.deepcopy(model.state_dict())\n            self.counter = 0\n\n# --- 5. MODEL MİMARİSİ ---\nclass SimpleRNNModel(nn.Module):\n    def __init__(self, vocab_size, embedding_dim, rnn_units):\n        super(SimpleRNNModel, self).__init__()\n        # DÜZELTME 2: padding_idx=0 eklendi\n        self.embedding = nn.Embedding(vocab_size, embedding_dim, padding_idx=0)\n        self.spatial_dropout = nn.Dropout2d(0.3)\n        self.rnn = nn.RNN(embedding_dim, rnn_units, batch_first=True)\n        self.fc1 = nn.Linear(rnn_units, 32)\n        self.relu = nn.ReLU()\n        self.dropout = nn.Dropout(0.3)\n        self.fc2 = nn.Linear(32, 1)\n\n    def forward(self, x):\n        embedded = self.embedding(x).permute(0, 2, 1)\n        dropped = self.spatial_dropout(embedded).permute(0, 2, 1)\n        out, _ = self.rnn(dropped)\n        last_out = out[:, -1, :] \n        dense_out = self.dropout(self.relu(self.fc1(last_out)))\n        return self.fc2(dense_out)\n\n# --- 6. MODEL BAŞLATMA VE OPTİMİZASYON ---\ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\nmodel = SimpleRNNModel(VOCAB_SIZE, EMBEDDING_DIM, RNN_UNITS).to(device)\n\ncriterion = nn.BCEWithLogitsLoss()\noptimizer = optim.Adam(model.parameters(), lr=1e-3)\n\nearly_stopping = EarlyStopping(patience=3)\nscheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=2)\n\n# --- 7. EĞİTİM DÖNGÜSÜ ---\nprint(\"\\n\" + \"=\" * 50)\nprint(f\"{'EĞİTİM BAŞLIYOR (SimpleRNN - PyTorch)':^50}\")\nprint(\"=\" * 50)\n\nfor epoch in range(EPOCHS):\n    model.train()\n    train_loss = 0\n    for X_batch, y_batch in train_loader:\n        X_batch, y_batch = X_batch.to(device), y_batch.to(device)\n        \n        optimizer.zero_grad()\n        predictions = model(X_batch)\n        loss = criterion(predictions, y_batch)\n        loss.backward()\n        \n        # DÜZELTME 3: Gradient Clipping (Modelin patlamasını engeller)\n        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n        \n        optimizer.step()\n        train_loss += loss.item()\n        \n    avg_train_loss = train_loss / len(train_loader)\n    \n    model.eval()\n    val_loss = 0\n    with torch.no_grad():\n        for X_batch, y_batch in val_loader:\n            X_batch, y_batch = X_batch.to(device), y_batch.to(device)\n            predictions = model(X_batch)\n            loss = criterion(predictions, y_batch)\n            val_loss += loss.item()\n            \n    avg_val_loss = val_loss / len(val_loader)\n    \n    print(f\"Epoch {epoch+1}/{EPOCHS} - loss: {avg_train_loss:.4f} - val_loss: {avg_val_loss:.4f}\")\n    \n    scheduler.step(avg_val_loss)\n    early_stopping(avg_val_loss, model)\n    \n    if early_stopping.early_stop:\n        print(\"\\n Early stopping tetiklendi! Eğitim durduruluyor.\")\n        break\n\nmodel.load_state_dict(early_stopping.best_weights)\nprint(\" En iyi ağırlıklar modele geri yüklendi.\")\n\n# --- 8. DEĞERLENDİRME ---\nmodel.eval()\ny_pred_rnn, y_prob_rnn, y_true = [], [], []\n\nwith torch.no_grad():\n    for X_batch, y_batch in val_loader:\n        X_batch = X_batch.to(device)\n        logits = model(X_batch)\n        probs = torch.sigmoid(logits).cpu().numpy().flatten()\n        \n        y_prob_rnn.extend(probs)\n        y_pred_rnn.extend((probs > 0.5).astype(int))\n        y_true.extend(y_batch.numpy().flatten())\n\nprint(\"\\nModel 2 Sonuçları (SimpleRNN PyTorch):\")\nprint(\"-\" * 45)\nprint(f\" Accuracy: {accuracy_score(y_true, y_pred_rnn):.4f}\")\nprint(f\" F1-Score: {f1_score(y_true, y_pred_rnn):.4f}\")\nprint(f\" ROC-AUC:  {roc_auc_score(y_true, y_prob_rnn):.4f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-17T13:22:52.477368Z","iopub.execute_input":"2026-03-17T13:22:52.477633Z","iopub.status.idle":"2026-03-17T13:22:59.842085Z","shell.execute_reply.started":"2026-03-17T13:22:52.477606Z","shell.execute_reply":"2026-03-17T13:22:59.840863Z"}},"outputs":[{"name":"stdout","text":"\n==================================================\n      EĞİTİM BAŞLIYOR (SimpleRNN - PyTorch)       \n==================================================\n","output_type":"stream"},{"name":"stderr","text":"/usr/local/lib/python3.12/dist-pa