ESSING)\nimport re\n# Stopwords listesi - İngilizce'deki anlam taşımayan kelimeler\n# Örnek: \"the\", \"is\", \"at\", \"which\", \"on\" gibi\nfrom nltk.corpus import stopwords\nstop_words = set(stopwords.words('english'))\n\nfrom nltk.stem import WordNetLemmatizer\n# Lemmatizer - Kelimeleri kök formuna dönüştürür\n# Örnek: \"running\" → \"run\", \"better\" → \"good\", \"cats\" → \"cat\"\nlemmatizer = WordNetLemmatizer()\n\n#Tweet metnini temizleyen ve standartlaştıran fonksiyon.\ndef clean_text(text):\n    text=text.lower()\n\n    text = re.sub(r'http\\S+|www\\S+|https\\S+', '', text, flags=re.MULTILINE)\n\n    text = re.sub(r'<.*?>', '', text)\n    text = re.sub(r'@\\w+', '', text)\n    text = re.sub(r'#', '', text)\n    text = re.sub(r'[^\\w\\s]', '', text)\n    text = re.sub(r'\\d+', '', text)\n    text = re.sub(r'\\s+', ' ', text).strip()\n    words = text.split()\n    words = [lemmatizer.lemmatize(word) for word in words if word not in stop_words]\n\n    return ' '.join(words)\n    \n\n# Ön işlemeyi uygula\nprint(\"\\n Metin ön işleme uygulanıyor...\")\nprint(\"\\nÖrnek dönüşümler:\")\nfor i in range(3):\n    original = train_df['text'].iloc[i]\n    cleaned = clean_text(original)\n    print(f\"\\n Orijinal: '{original}'\")\n    print(f\" Temiz: '{cleaned}'\")\n    \ntrain_df['clean_text'] = train_df['text'].apply(clean_text)\ntest_df['clean_text'] = test_df['text'].apply(clean_text)\n                                             \nprint(f\"\\n Ön işleme tamamlandı!\")\nprint(f\" Train: {len(train_df)} tweet temizlendi\")\nprint(f\" Test: {len(test_df)} tweet temizlendi\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-17T13:22:51.079920Z","iopub.execute_input":"2026-03-17T13:22:51.080267Z","iopub.status.idle":"2026-03-17T13:22:51.682492Z","shell.execute_reply.started":"2026-03-17T13:22:51.080206Z","shell.execute_reply":"2026-03-17T13:22:51.681601Z"}},"outputs":[{"name":"stdout","text":"\n Metin ön işleme uygulanıyor...\n\nÖrnek dönüşümler:\n\n Orijinal: 'Our Deeds are the Reason of this #earthquake May ALLAH Forgive us all'\n Temiz: 'deed reason earthquake may allah forgive u'\n\n Orijinal: 'Forest fire near La Ronge Sask. Canada'\n Temiz: 'forest fire near la ronge sask canada'\n\n Orijinal: 'All residents asked to 'shelter in place' are being notified by officers. No other evacuation or shelter in place orders are expected'\n Temiz: 'resident asked shelter place notified officer evacuation shelter place order expected'\n\n Ön işleme tamamlandı!\n Train: 7613 tweet temizlendi\n Test: 3263 tweet temizlendi\n","output_type":"stream"}],"execution_count":39},{"cell_type":"code","source":"# BÖLÜM 4: ÖZELLİK MÜHENDİSLİĞİ (FEATURE ENGINEERING)\n\"\"\"\nFeature Engineering = Ham veriden model için anlamlı özellikler çıkarmak.\nİki farklı yaklaşım kullanacağız:\nA) TF-IDF (Klasik ML için):\n- Term Frequency (TF): Bir kelimenin bir dokümandaki sıklığı\n- Inverse Document Frequency (IDF): Kelimenin tüm dokümanlardaki nadirligi\n- TF-IDF = TF × IDF → Nadir ama önemli kelimelere yüksek ağırlık verir\nÖrnek: \"the\" kelimesi her yerde geçer → düşük IDF → düşük TF-IDF\n\"earthquake\" kelimesi nadir → yüksek IDF → yüksek TF-IDF\nB) Word Embeddings (Derin Öğrenme için):\n- Her kelimeye sabit boyutlu bir vektör atanır\n- Benzer anlamlı kelimeler yakın vektörlere sahip olur\n- Örnek: \"fire\" ve \"blaze\" yakın vektörlere sahip\n- Tokenizer + Padding kullanarak hazırlanır\n\"\"\"\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-17T13:22:51.683510Z","iopub.execute_input":"2026-03-17T13:22:51.683740Z","iopub.status.idle":"2026-03-17T13:22:51.689504Z","shell.execute_reply.started":"2026-03-17T13:22:51.683715Z","shell.execute_reply":"2026-03-17T13:22:51.688665Z"}},"outputs":[{"execution_count":40,"output_type":"execute_result","data":{"text/plain":"'\\nFeature Engineering = Ham veriden model için anlamlı özellikler çıkarmak.\\nİki farklı yaklaşım kullanacağız:\\nA) TF-IDF (Klasik ML için):\\n- Ter